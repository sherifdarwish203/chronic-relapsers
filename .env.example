# Database
DATABASE_URL=postgres://recovery:recovery_dev@localhost:5432/recovery_db

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string_in_production
JWT_PATIENT_EXPIRY=30d
JWT_FACILITATOR_EXPIRY=8h

# Server
PORT=3000
NODE_ENV=development

# Puppeteer (set for production VPS)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Client (Vite)
VITE_API_URL=http://localhost:3000
